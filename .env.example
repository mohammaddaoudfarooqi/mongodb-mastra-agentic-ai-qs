# Marshal — environment
APP_NAME=Marshal
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER/?retryWrites=true&w=majority
MONGODB_DB=marshal
VOYAGE_API_KEY=
# Optional: leave unset to use the MongoDB-hosted Voyage endpoint (https://ai.mongodb.com/v1)
VOYAGE_BASE_URL=
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5
# Optional gateway routing for the LLM (Anthropic API root, e.g. .../anthropic/v1)
LLM_BASE_URL=
# Gateway key, sent as the `api-key` header when LLM_BASE_URL points at an APIM gateway
GROVE_API_KEY=
PORT=8000
RRF_K=60
